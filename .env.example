# Database Configuration
# Individual variables can be used for reference, but the application 
# primarily uses NOSTALGIA_CONNECTION_STRING.
DB_USER=root
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=3306
DB_NAME=nostalgia

# MySQL Connection String (DSN)
# Format: user:password@tcp(host:port)/dbname?charset=utf8mb4&parseTime=True&loc=Local
NOSTALGIA_CONNECTION_STRING=root:@tcp(localhost:3306)/nostalgia?charset=utf8mb4&parseTime=True&loc=Local

# Application Paths
# Path to the media directory to be scanned
NOSTALGIA_SCAN_PATH=/path/to/your/media

# Base directory where Nostalgia will copy and manage files
NOSTALGIA_HOME_PATH=/path/to/gostalgia/storage

# Directory where thumbnails will be generated
NOSTALGIA_THUMB_TARGET_PATH=/path/to/gostalgia/thumbnails
