                    "application/json"
                ],
                "tags": [
                    "directories"
                ],
                "summary": "Buscar directorios",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Texto a buscar en el nombre",
                        "name": "contains",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Fecha mínima (YYYY-MM-DD)",
                        "name": "after",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Fecha máxima (YYYY-MM-DD)",
                        "name": "before",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 1,
                        "description": "Número de página",
                        "name": "page",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "default": 50,
                        "description": "Resultados por página",
                        "name": "per_page",
                        "in": "query"
                    }
